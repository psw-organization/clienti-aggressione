generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "sqlite"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

enum UserRole {
  admin
  operator
}

enum LeadStatus {
  new
  reviewed
  contacted
  qualified
  discarded
}

enum ReviewsRange {
  none
  low
  medium
  high
}

enum WebsitePresence {
  official
  social
  directory
  none
}

enum PriorityLevel {
  low
  medium
  high
}

enum SearchJobStatus {
  running
  completed
  failed
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         UserRole @default(operator)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  searchJobs SearchJob[]
}

model Lead {
  id                 String          @id @default(uuid())
  businessName       String
  slug               String          @unique
  category           String?
  address            String?
  city               String?
  province           String?
  region             String?
  country            String          @default("IT")
  latitude           Decimal?
  longitude          Decimal?
  phone              String?
  email              String?
  rating             Float?
  reviewsCount       Int?
  reviewsRange       ReviewsRange    @default(none)

  websitePresence    WebsitePresence @default(none)
  hasOfficialWebsite Boolean         @default(false)
  officialWebsiteUrl String?
  instagramUrl       String?
  facebookUrl        String?
  sourceUrl          String?
  provider           String
  providerRaw        String?

  isVerifiedActive   Boolean         @default(true)
  chainDetected      Boolean         @default(false)

  leadScore          Int             @default(0)
  scoreReasons       String          @default("[]")
  priorityLevel      PriorityLevel   @default(medium)
  status             LeadStatus      @default(new)
  internalNotes      String?

  normalizedName     String?
  normalizedPhone    String?
  normalizedEmail    String?
  normalizedAddress  String?
  normalizedDomain   String?

  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  sources            LeadSource[]

  @@index([provider])
  @@index([leadScore])
  @@index([status])
  @@index([normalizedName])
  @@index([normalizedPhone])
  @@index([normalizedEmail])
  @@index([normalizedDomain])
}

model LeadSource {
  id         String   @id @default(uuid())
  leadId     String
  sourceUrl  String
  type       String   // e.g. "official", "facebook", "instagram", "directory"
  confidence Float    @default(1.0)
  createdAt  DateTime @default(now())

  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model SearchJob {
  id              String          @id @default(uuid())
  providerId      String
  status          SearchJobStatus @default(running)
  params          String
  rawResultsCount Int             @default(0)
  validResults    Int             @default(0)
  errorMessage    String?
  startedAt       DateTime        @default(now())
  finishedAt      DateTime?

  user            User?           @relation(fields: [userId], references: [id])
  userId          String?
}

model ProviderConfig {
  id         String   @id @default(uuid())
  providerId String   @unique
  enabled    Boolean  @default(true)
  config     String   @default("{}")
  updatedAt  DateTime @updatedAt
}

model ScoringConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  config    String
  updatedAt DateTime @updatedAt
}

model BlacklistDomain {
  id        String   @id @default(uuid())
  domain    String   @unique
  reason    String?
  createdAt DateTime @default(now())
}

model BlacklistChain {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
}
